{
  "name": "mylifefolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "seed": "tsx scripts/seed.ts",
    "seed:reset": "tsx scripts/seed-reset.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:rls": "vitest run src/test/rls/ --no-file-parallelism --environment node --config vitest.rls.config.ts",
    "test:rls:slow": "vitest run src/test/rls/ --no-file-parallelism --environment node --config vitest.rls.config.ts --pool forks --poolOptions.forks.maxForks 1",
    "test:edge": "vitest run src/test/edge/ --reporter=verbose --config vitest.edge.config.ts",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:codegen": "npx playwright codegen http://localhost:5173"
  },
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.16.0",
    "@mui/material": "^5.16.0",
    "@mui/x-date-pickers": "^6.19.0",
    "@supabase/supabase-js": "^2.89.0",
    "@types/file-saver": "^2.0.7",
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "date-fns": "^2.30.0",
    "docx": "^9.5.1",
    "drizzle-orm": "^0.45.2",
    "electron-updater": "^6.8.3",
    "file-saver": "^2.0.5",
    "imask": "^7.6.1",
    "jspdf": "^4.2.0",
    "pdf-lib": "^1.17.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.0",
    "react-imask": "^7.6.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "remark-gfm": "^4.0.1",
    "supabase": "^2.70.5"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^8",
    "jsdom": "^28.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite": "^7.3.0",
    "vitest": "^4.0.18"
  }
}
